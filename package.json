{
  "name": "wishop-extension",
  "description": "微店管家 Chrome MV3 extension",
  "private": true,
  "version": "0.0.50",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "push": "npm run compile && npm run build && npm version patch -m 'chore: v%s' && git push --follow-tags",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.3",
    "antd": "^6.4.2",
    "axios": "^1.16.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "typescript": "^5.9.3",
    "wxt": "^0.20.26"
  }
}
